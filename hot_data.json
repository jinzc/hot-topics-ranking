        .hot-item:hover::before { opacity: 1; }
        .hot-item.top1::before { background: linear-gradient(to bottom, #ffd700, #ff8c00); opacity: 1; }
        .hot-item.top2::before { background: linear-gradient(to bottom, #c0c0c0, #a0a0a0); opacity: 1; }
        .hot-item.top3::before { background: linear-gradient(to bottom, #cd7f32, #b87333); opacity: 1; }

        .item-header {
